---
import { Image } from "astro:assets";
import oliveBranch from "../../assets/images/about-olive-branch-trimmed.webp";

const phone = "+79167801064";
const phoneLabel = "+7 (916) 780-10-64";
const mapsUrl = "https://yandex.ru/maps/org/sansara/66504653176/";
const mapWidgetUrl =
  "https://yandex.ru/map-widget/v1/?text=%D0%A1%D0%B0%D0%BD%D1%81%D0%B0%D1%80%D0%B0%2C%20%D0%9A%D0%BE%D1%80%D0%BE%D0%BB%D1%91%D0%B2%2C%20%D0%BF%D1%80%D0%BE%D1%81%D0%BF%D0%B5%D0%BA%D1%82%20%D0%9A%D0%BE%D1%81%D0%BC%D0%BE%D0%BD%D0%B0%D0%B2%D1%82%D0%BE%D0%B2%2C%204%D0%92&z=16";
---

<section id="contacts" class="contacts" aria-labelledby="contacts-title">
  <div class="contacts__decor" aria-hidden="true">
    <Image
      src={oliveBranch}
      alt=""
      class="contacts__branch"
      loading="lazy"
      decoding="async"
      widths={[360, 560, 760]}
      sizes="(max-width: 760px) 82vw, 46vw"
    />
  </div>

  <div class="contacts__shell container">
    <div class="contacts__header" data-animate="rise-sm">
      <p class="contacts__eyebrow">Ждем вас каждый день</p>
      <h2 class="contacts__title" id="contacts-title">Контакты</h2>
    </div>

    <div class="contacts__content">
      <address
        class="contacts__list"
        aria-label="Контактная информация"
        data-animate="rise-sm"
        style="--motion-delay: 90ms;"
      >
        <a class="contacts__item" href={mapsUrl} target="_blank" rel="noreferrer">
          <span class="contacts__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" focusable="false">
              <path d="M12 21s7-5.1 7-11a7 7 0 1 0-14 0c0 5.9 7 11 7 11Z"></path>
              <circle cx="12" cy="10" r="2.4"></circle>
            </svg>
          </span>
          <span class="contacts__item-copy">
            <span class="contacts__label">Адрес</span>
            <strong>г. Королёв, проспект Космонавтов, 4В</strong>
            <span>Вход со стороны прогулочной зоны</span>
          </span>
        </a>

        <a class="contacts__item" href={`tel:${phone}`}>
          <span class="contacts__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" focusable="false">
              <path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.5 19.5 0 0 1-6-6A19.8 19.8 0 0 1 2.1 4.2 2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1 1 .4 1.9.7 2.8a2 2 0 0 1-.5 2.1L8 9.9a16 16 0 0 0 6.1 6.1l1.3-1.3a2 2 0 0 1 2.1-.5c.9.3 1.8.6 2.8.7a2 2 0 0 1 1.7 2Z"></path>
            </svg>
          </span>
          <span class="contacts__item-copy">
            <span class="contacts__label">Телефон</span>
            <strong>{phoneLabel}</strong>
            <span>Для брони столов и вопросов по меню</span>
          </span>
        </a>

        <div class="contacts__item">
          <span class="contacts__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" focusable="false">
              <circle cx="12" cy="12" r="9"></circle>
              <path d="M12 7v5l3.3 2"></path>
            </svg>
          </span>
          <span class="contacts__item-copy">
            <span class="contacts__label">Режим работы</span>
            <strong>Ежедневно до 23:00</strong>
            <span>Лучше забронировать стол заранее</span>
          </span>
        </div>
      </address>

      <div class="contacts__aside" data-animate="rise-sm" style="--motion-delay: 150ms;">
        <p>
          Если планируете семейный ужин или встречу с друзьями, позвоните нам:
          подберем спокойный стол и время без лишней суеты.
        </p>
        <a class="contacts__button" href={`tel:${phone}`}>Забронировать стол</a>
      </div>
    </div>

    <div
      class="contacts__map-block"
      aria-label="Карта ресторана Сансара"
      data-animate="rise-sm"
      style="--motion-delay: 210ms;"
    >
      <a class="contacts__route" href={mapsUrl} target="_blank" rel="noreferrer">
        Построить маршрут
      </a>

      <div class="contacts__map">
        <iframe
          src={mapWidgetUrl}
          title="Сансара на карте Королёва"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
    </div>
  </div>
</section>

<style>
  .contacts {
    position: relative;
    isolation: isolate;
    padding-block: clamp(82px, 9vw, 128px) clamp(76px, 8vw, 108px);
    overflow: hidden;
    background: var(--color-bg);
    color: var(--color-text);
  }

  .contacts::before {
    position: absolute;
    inset: 0 0 auto;
    height: 1px;
    background: linear-gradient(90deg, rgb(104 112 89 / 0), rgb(104 112 89 / 0.18), rgb(104 112 89 / 0));
    content: "";
  }

  .contacts__decor {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  .contacts__branch {
    position: absolute;
    right: max(-74px, calc((100vw - var(--container-width)) / 2 - 112px));
    top: clamp(70px, 8vw, 108px);
    width: min(48vw, 620px);
    height: auto;
    opacity: 0.12;
    filter: saturate(0.7) contrast(0.92);
    transform: rotate(-7deg);
    transform-origin: 68% 50%;
    user-select: none;
  }

  .contacts__shell {
    position: relative;
    z-index: 1;
  }

  .contacts__header {
    margin-left: clamp(0px, 4vw, 62px);
  }

  .contacts__eyebrow {
    margin: 0 0 18px;
    color: var(--color-olive);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    line-height: 1.5;
    text-transform: uppercase;
  }

  .contacts__title {
    margin: 0;
    color: var(--color-text);
    font-family: var(--font-heading);
    font-size: clamp(3.35rem, 7vw, 6.2rem);
    font-weight: 400;
    letter-spacing: 0;
    line-height: 1;
  }

  .contacts__content {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(290px, 0.78fr);
    gap: clamp(34px, 5vw, 76px);
    align-items: center;
    margin-top: clamp(36px, 5.4vw, 66px);
    margin-left: clamp(0px, 4vw, 62px);
  }

  .contacts__list {
    display: grid;
    gap: clamp(18px, 2.4vw, 28px);
    margin: 0;
    font-style: normal;
  }

  .contacts__item {
    display: grid;
    grid-template-columns: 44px minmax(0, 1fr);
    gap: 18px;
    align-items: start;
    color: inherit;
    text-decoration: none;
  }

  .contacts__item[href] {
    transition:
      color 180ms ease,
      transform 180ms ease;
  }

  .contacts__item[href]:hover {
    color: var(--color-olive);
    transform: translateX(2px);
  }

  .contacts__item:focus-visible,
  .contacts__button:focus-visible,
  .contacts__route:focus-visible {
    outline: 3px solid var(--color-lemon);
    outline-offset: 4px;
  }

  .contacts__icon {
    display: grid;
    place-items: center;
    width: 44px;
    height: 44px;
    border: 1px solid rgb(104 112 89 / 0.22);
    border-radius: 999px;
    background: rgb(196 202 155 / 0.2);
    color: var(--color-olive);
    transition:
      background-color var(--motion-duration-base) var(--motion-ease),
      border-color var(--motion-duration-base) var(--motion-ease),
      transform var(--motion-duration-base) var(--motion-ease);
  }

  .contacts__item[href]:hover .contacts__icon {
    border-color: rgb(104 112 89 / 0.34);
    background: rgb(196 202 155 / 0.32);
    transform: scale(1.04);
  }

  .contacts__icon svg {
    width: 23px;
    height: 23px;
    fill: none;
    stroke: currentcolor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.8;
  }

  .contacts__item-copy {
    display: grid;
    gap: 5px;
    max-width: 460px;
    color: rgb(71 52 45 / 0.72);
    font-size: clamp(0.97rem, 1.4vw, 1.08rem);
    line-height: 1.58;
  }

  .contacts__label {
    color: rgb(104 112 89 / 0.88);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    line-height: 1.35;
    text-transform: uppercase;
  }

  .contacts__item-copy strong {
    color: var(--color-text);
    font-weight: 600;
  }

  .contacts__aside {
    position: relative;
    max-width: 430px;
    padding-left: clamp(30px, 4vw, 58px);
    border-left: 1px solid rgb(104 112 89 / 0.18);
  }

  .contacts__aside p {
    margin: 0;
    color: rgb(71 52 45 / 0.76);
    font-size: clamp(1rem, 1.4vw, 1.12rem);
    line-height: 1.72;
  }

  .contacts__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    min-width: 244px;
    margin-top: clamp(26px, 3.8vw, 42px);
    padding: 15px 28px 11px;
    border: 1px solid rgb(71 52 45 / 0.1);
    border-radius: var(--radius-md);
    background: var(--color-olive);
    box-shadow: 0 16px 34px rgb(71 52 45 / 0.12);
    color: #fffaf0;
    font-family: var(--font-heading);
    font-size: 1.06rem;
    letter-spacing: 0.2em;
    line-height: 1;
    text-align: center;
    text-decoration: none;
    transition:
      background-color 180ms ease,
      box-shadow 180ms ease,
      transform 180ms ease;
  }

  .contacts__button:hover {
    background: var(--color-text);
    box-shadow: 0 18px 38px rgb(71 52 45 / 0.16);
    transform: translateY(-2px);
  }

  .contacts__map-block {
    margin-top: clamp(54px, 7vw, 88px);
  }

  .contacts__route {
    display: table;
    margin: 0 0 clamp(16px, 2vw, 22px) auto;
    color: var(--color-olive);
    font-size: 0.86rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    line-height: 1.4;
    text-decoration: underline;
    text-decoration-color: rgb(104 112 89 / 0.32);
    text-underline-offset: 5px;
    transition:
      color 180ms ease,
      text-decoration-color 180ms ease;
  }

  .contacts__route:hover {
    color: var(--color-text);
    text-decoration-color: rgb(71 52 45 / 0.48);
  }

  .contacts__map {
    position: relative;
    min-height: 420px;
    overflow: hidden;
  }

  .contacts__map::after {
    position: absolute;
    inset: 0;
    background: rgb(249 242 229 / 0.34);
    content: "";
    mix-blend-mode: multiply;
    pointer-events: none;
  }

  .contacts__map iframe {
    display: block;
    width: 100%;
    height: 100%;
    min-height: 420px;
    border: 0;
    filter: sepia(0.12) saturate(0.88) contrast(0.96);
  }

  @media (prefers-reduced-motion: reduce) {
    .contacts__item[href],
    .contacts__icon,
    .contacts__button,
    .contacts__route {
      transition: none;
    }

    .contacts__item[href]:hover,
    .contacts__item[href]:hover .contacts__icon,
    .contacts__button:hover {
      transform: none;
    }
  }

  @media (max-width: 860px) {
    .contacts {
      padding-block: 76px 82px;
    }

    .contacts__branch {
      right: -118px;
      top: 108px;
      width: min(78vw, 520px);
      opacity: 0.08;
    }

    .contacts__header,
    .contacts__content {
      margin-left: 0;
    }

    .contacts__content {
      grid-template-columns: 1fr;
      gap: 34px;
      align-items: start;
    }

    .contacts__aside {
      max-width: 620px;
      padding-top: 32px;
      padding-left: 0;
      border-top: 1px solid rgb(104 112 89 / 0.18);
      border-left: 0;
    }

    .contacts__map {
      min-height: 360px;
    }

    .contacts__map iframe {
      min-height: 360px;
    }
  }

  @media (max-width: 560px) {
    .contacts {
      padding-block: 70px 72px;
    }

    .contacts__eyebrow {
      margin-bottom: 14px;
      font-size: 0.72rem;
    }

    .contacts__title {
      font-size: clamp(3.1rem, 16vw, 4.5rem);
    }

    .contacts__content {
      margin-top: 32px;
    }

    .contacts__item {
      grid-template-columns: 40px minmax(0, 1fr);
      gap: 14px;
    }

    .contacts__icon {
      width: 40px;
      height: 40px;
    }

    .contacts__icon svg {
      width: 21px;
      height: 21px;
    }

    .contacts__button {
      width: 100%;
      min-width: 0;
      padding-inline: 20px;
      letter-spacing: 0.12em;
    }

    .contacts__map {
      min-height: 320px;
    }

    .contacts__map iframe {
      min-height: 320px;
    }
  }
</style>
