---
import { Image } from "astro:assets";
import heroMark from "../../assets/brand/sansara-arch-mark-white.png";
import heroWordmark from "../../assets/brand/sansara-wordmark-white.png";
import heroBackground from "../../assets/images/sansara-hero-background.png";
---

<section id="hero" class="hero" aria-labelledby="hero-title" data-hero-parallax>
  <Image
    src={heroBackground}
    alt=""
    class="hero__image"
    data-hero-parallax-image
    loading="eager"
    decoding="async"
    fetchpriority="high"
    widths={[640, 960, 1280, 1672]}
    sizes="100vw"
  />
  <div class="hero__shade" aria-hidden="true"></div>

  <div class="hero__content container">
    <p
      class="hero__city"
      aria-label="Королев"
      data-animate="fade"
      style="--motion-delay: 120ms;"
    >
      К о р о л е в
    </p>
    <Image
      src={heroMark}
      alt=""
      class="hero__mark"
      loading="eager"
      decoding="async"
    />
    <h1 class="sr-only" id="hero-title">Сансара</h1>
    <Image
      src={heroWordmark}
      alt=""
      class="hero__wordmark"
      loading="eager"
      decoding="async"
    />
    <div
      class="hero__actions"
      aria-label="Основные действия"
      data-animate="rise-sm"
      style="--motion-delay: 220ms;"
    >
      <a class="hero__button" href="#about" aria-label="Меню">
        <span class="hero__button-text">М е н ю</span>
      </a>
    </div>
  </div>
</section>

<script>
  const hero = document.querySelector("[data-hero-parallax]");
  const image = hero?.querySelector("[data-hero-parallax-image]");
  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

  if (hero instanceof HTMLElement && image instanceof HTMLElement) {
    let isTicking = false;

    const updateParallax = () => {
      if (reduceMotion.matches) {
        image.style.removeProperty("--hero-parallax-y");
        isTicking = false;
        return;
      }

      const rect = hero.getBoundingClientRect();
      const viewportHeight = window.innerHeight || document.documentElement.clientHeight;

      if (rect.bottom < 0 || rect.top > viewportHeight) {
        isTicking = false;
        return;
      }

      const scrollInsideHero = Math.min(Math.max(-rect.top, 0), rect.height);
      const offset = Math.min(scrollInsideHero * 0.2, 110);

      image.style.setProperty("--hero-parallax-y", `${offset.toFixed(2)}px`);
      isTicking = false;
    };

    const requestParallaxUpdate = () => {
      if (!isTicking) {
        window.requestAnimationFrame(updateParallax);
        isTicking = true;
      }
    };

    window.addEventListener("scroll", requestParallaxUpdate, { passive: true });
    window.addEventListener("resize", requestParallaxUpdate);
    reduceMotion.addEventListener("change", requestParallaxUpdate);

    updateParallax();
  }
</script>

<style>
  .hero {
    --hero-parallax-y: 0px;

    position: relative;
    isolation: isolate;
    display: grid;
    min-height: 100vh;
    height: 100vh;
    overflow: hidden;
    color: #fffaf0;
    background: var(--color-olive);
  }

  .hero__image {
    position: absolute;
    top: -110px;
    right: 0;
    left: 0;
    z-index: -2;
    width: 100%;
    height: calc(100% + 220px);
    filter: sepia(0.18) saturate(1.12) brightness(0.96) contrast(1.04);
    object-fit: cover;
    object-position: center;
    transform: translate3d(0, var(--hero-parallax-y), 0);
    will-change: transform;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__shade {
      animation: none;
    }

    .hero__image {
      transform: none;
      will-change: auto;
    }
  }

  .hero__shade {
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      linear-gradient(0deg, rgb(220 124 40 / 0.14), rgb(249 242 229 / 0.08)),
      radial-gradient(circle at 50% 42%, rgb(71 52 45 / 0.04), rgb(71 52 45 / 0.34) 72%),
      linear-gradient(180deg, rgb(20 18 14 / 0.02), rgb(20 18 14 / 0.14) 44%, rgb(20 18 14 / 0.34));
  }

  :global(html.motion-ready) .hero__shade {
    animation: hero-shade-in var(--motion-duration-slow) var(--motion-ease) both;
  }

  @keyframes hero-shade-in {
    from {
      opacity: 0.72;
    }

    to {
      opacity: 1;
    }
  }

  .hero__content {
    display: grid;
    align-content: center;
    justify-items: center;
    min-height: inherit;
    padding-block: 68px 0;
    text-align: center;
  }

  .hero__city {
    margin: 0 0 18px;
    color: rgb(255 250 240 / 0.9);
    font-family: var(--font-heading);
    font-size: 0.95rem;
    line-height: 1.4;
    text-shadow: 0 10px 32px rgb(0 0 0 / 0.32);
  }

  .hero__mark {
    width: 92px;
    height: auto;
    margin-bottom: 22px;
    opacity: 0.96;
    filter: drop-shadow(0 10px 28px rgb(0 0 0 / 0.24));
  }

  .hero__wordmark {
    width: min(100%, 560px);
    height: auto;
    filter: drop-shadow(0 18px 48px rgb(0 0 0 / 0.3));
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 14px;
    margin-top: 24px;
  }

  .hero__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 146px;
    min-height: 46px;
    padding: 11px 28px;
    border-radius: var(--radius-md);
    border: 1px solid rgb(255 250 240 / 0.5);
    background: rgb(104 112 89 / 0.82);
    box-shadow: 0 18px 44px rgb(0 0 0 / 0.24);
    color: #fffaf0;
    font-family: var(--font-heading);
    font-size: 1.08rem;
    font-weight: 400;
    line-height: 1;
    text-decoration: none;
    white-space: nowrap;
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      background-color 180ms ease,
      color 180ms ease;
  }

  .hero__button-text {
    display: block;
    transform: translateY(3px);
  }

  .hero__button:hover {
    transform: translateY(-2px);
    border-color: rgb(255 250 240 / 0.72);
    background: rgb(71 52 45 / 0.82);
  }

  .hero__button:focus-visible {
    outline: 3px solid var(--color-lemon);
    outline-offset: 4px;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__button {
      transition: none;
    }

    .hero__button:hover {
      transform: none;
    }
  }

  @media (max-width: 720px) {
    .hero {
      min-height: 600px;
      height: 100vh;
      height: 100svh;
    }

    .hero__content {
      padding-block: 58px 0;
    }

    .hero__mark {
      width: 76px;
      margin-bottom: 18px;
    }

    .hero__wordmark {
      width: min(100%, 270px);
    }

    .hero__city {
      font-size: 0.9rem;
    }

    .hero__actions {
      width: 100%;
    }

    .hero__button {
      width: min(100%, 180px);
    }
  }

  @media (min-width: 721px) and (max-width: 1080px) {
    .hero__wordmark {
      width: min(100%, 480px);
    }
  }

  @media (max-width: 380px) {
    .hero__wordmark {
      width: min(100%, 248px);
    }
  }
</style>
