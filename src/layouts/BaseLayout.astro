---
import "../styles/global.css";
import FloatingContacts from "../components/FloatingContacts.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Сансара",
  description = "Семейный ресторан европейской кухни.",
} = Astro.props;

const publicBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const publicPath = (path: string) => `${publicBase}${path.replace(/^\//, "")}`;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" href={publicPath("favicon.ico")} sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href={publicPath("favicon-32x32.png")} />
    <link rel="icon" type="image/png" sizes="16x16" href={publicPath("favicon-16x16.png")} />
    <link rel="apple-touch-icon" sizes="180x180" href={publicPath("apple-touch-icon.png")} />
    <title>{title}</title>
    <script is:inline>
      if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
        document.documentElement.classList.add("motion-ready", "footer-parallax-enabled");
      }
    </script>
  </head>
  <body>
    <slot />
    <FloatingContacts />
    <script>
      const animatedElements = Array.from(document.querySelectorAll("[data-animate]"));
      const reduceMotionQuery = window.matchMedia("(prefers-reduced-motion: reduce)");

      if (animatedElements.length > 0) {
        const observedElements = new WeakSet<Element>();
        const hydratedIslands = new WeakSet<Element>();
        const islands = Array.from(document.querySelectorAll("astro-island"));

        const revealElement = (element: Element) => {
          element.classList.add("is-visible");
        };

        const getHydrationReadyElements = (root: ParentNode = document) => {
          return Array.from(root.querySelectorAll("[data-animate]")).filter(
            (element) => {
              const island = element.closest("astro-island");

              return !(island instanceof Element) || hydratedIslands.has(island);
            },
          );
        };

        const revealHydrationReadyElements = () => {
          getHydrationReadyElements().forEach(revealElement);
        };

        if (reduceMotionQuery.matches || !("IntersectionObserver" in window)) {
          document.documentElement.classList.remove("motion-ready");
          revealHydrationReadyElements();
        } else {
          const revealObserver = new IntersectionObserver(
            (entries, observer) => {
              entries.forEach((entry) => {
                if (entry.isIntersecting) {
                  revealElement(entry.target);
                  observer.unobserve(entry.target);
                }
              });
            },
            {
              rootMargin: "0px 0px -8% 0px",
              threshold: 0.16,
            },
          );

          const observeHydrationReadyElements = (root: ParentNode = document) => {
            getHydrationReadyElements(root).forEach((element) => {
              if (observedElements.has(element)) {
                return;
              }

              observedElements.add(element);
              revealObserver.observe(element);
            });
          };

          islands.forEach((island) => {
            if (island.hasAttribute("client-render-time")) {
              hydratedIslands.add(island);
            }

            island.addEventListener(
              "astro:hydrate",
              () => {
                hydratedIslands.add(island);
                observeHydrationReadyElements(island);
              },
              { once: true },
            );
          });

          observeHydrationReadyElements();

          reduceMotionQuery.addEventListener("change", () => {
            if (reduceMotionQuery.matches) {
              revealObserver.disconnect();
              document.documentElement.classList.remove("motion-ready");
              revealHydrationReadyElements();
            }
          });
        }
      }
    </script>
  </body>
</html>
