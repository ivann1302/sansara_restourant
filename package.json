{
  "name": "landing-corporate-starter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Starter for Astro, React and optional PHP-backed landing and corporate websites.",
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=9.6.5"
  },
  "scripts": {
